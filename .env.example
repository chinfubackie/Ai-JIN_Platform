# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าตามเครื่อง server
# ใช้ทั้งกับ docker compose และ webapp/app.py (ผ่าน python-dotenv)

# ── Storage paths (bind mounts เข้า container) ──────────────────────
# บน Linux server แนะนำใช้ path แบบ absolute เช่น /srv/aijin/dataset
DATASET_PATH=./dataset
RUNS_PATH=./runs
MODEL_PATH=./models

# ── Label Studio (annotation service) ───────────────────────────────
# ใน docker compose ค่า LABEL_STUDIO_URL ของ webapp ถูก override เป็น
# http://label-studio:8080 อัตโนมัติแล้ว (ดู docker-compose.yml) — ตัวแปรนี้
# มีผลเฉพาะตอนรัน webapp/app.py แบบ standalone (ไม่ผ่าน docker compose)
LABEL_STUDIO_URL=http://localhost:8085
# สร้าง token จาก Label Studio UI: Account & Settings > Access Token
LABEL_STUDIO_TOKEN=

# ── YOLO training server (ถ้ามีเครื่อง GPU แยกสำหรับเทรนโดยเฉพาะ) ──────
# ถ้าไม่มี server แยก ให้ปล่อยว่าง/ชี้ผิด ระบบจะ fallback ไปเทรนแบบ
# in-process บนเครื่องนี้เอง (ต้องมี ultralytics ติดตั้งและควรมี GPU)
YOLO_TRAIN_URL=http://host.docker.internal:8111

# ── Ollama (LLM assistant ในหน้า UI) ─────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava

# ── SQLite database (business data: projects/classes/images/...) ───
# ปล่อยว่าง/comment ไว้ = ใช้ default webapp/aijin.db — ใน docker compose
# ตัวแปรนี้ถูก override เป็น /data/aijin.db ที่ bind กับ volume aijin_db_data
# เพื่อให้ข้อมูลไม่หายเมื่อ container ถูกลบ/rebuild ไม่ต้องตั้งเองที่นี่
# AIJIN_DB_PATH=/path/to/aijin.db

# ── Camera live-stream port (ฟีเจอร์ browser-webcam) ────────────────
# ปล่อยว่าง = stream ใช้ origin/port เดียวกับ API (8501) ตั้งเฉพาะถ้าต้องการ
# แยกพอร์ตสำหรับ MJPEG/stream โดยเฉพาะ — ถ้าตั้งค่า ต้อง expose พอร์ตนี้
# เพิ่มใน docker-compose.yml (ports:) ด้วย
STREAM_PORT=
